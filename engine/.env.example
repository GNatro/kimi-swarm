# Kimi Swarm Engine — Configuration
# Copy this file to .env and customize for your setup

# Project paths
POLYBOT_ROOT=/home/grapho/projects/polybot
BUS_ROOT=/home/grapho/shared-context/polybot

# Engine tuning
MAX_CHUNK_TOKENS=150000
CHUNK_SAFETY_MARGIN=20000
PARTITION_THRESHOLD=120000

# Hook integration (Brain Stack)
BRAIN_STACK_ENABLED=true
WORK_TURN_WARNING=10
WORK_TURN_BLOCK=15

# Project-specific settings
# Set to the services you always want included in context
# (e.g., types, core utilities)
ALWAYS_INCLUDE_SHARED=true
